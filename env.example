# FisioHub - variáveis de ambiente de exemplo
# Copie este arquivo para .env.local e preencha com valores reais somente no ambiente local/Vercel.
# Nunca versione .env, .env.local, .env.production ou .env.vercel.

# Banco de dados principal - Neon/PostgreSQL
DATABASE_URL=COLOQUE_SUA_DATABASE_URL_AQUI
DATABASE_URL_UNPOOLED=COLOQUE_SUA_DATABASE_URL_UNPOOLED_AQUI
DATABASE_POOL_MAX=5

# Neon Auth / sessão
NEON_AUTH_BASE_URL=COLOQUE_SUA_NEON_AUTH_BASE_URL_AQUI
NEXT_PUBLIC_NEON_AUTH_BASE_URL=COLOQUE_SUA_NEON_AUTH_BASE_URL_PUBLICA_AQUI
NEON_AUTH_CLIENT_ID=COLOQUE_SEU_NEON_AUTH_CLIENT_ID_AQUI
NEON_AUTH_CLIENT_SECRET=COLOQUE_SEU_NEON_AUTH_CLIENT_SECRET_AQUI
NEON_AUTH_COOKIE_SECRET=COLOQUE_SEU_NEON_AUTH_COOKIE_SECRET_AQUI
AUTH_SECRET=COLOQUE_SEU_AUTH_SECRET_AQUI
NEXTAUTH_SECRET=COLOQUE_SEU_NEXTAUTH_SECRET_AQUI

# Next.js / Deploy
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="FisioHub"
NODE_ENV=development

# Inteligência artificial
OPENAI_API_KEY=COLOQUE_SUA_OPENAI_API_KEY_AQUI
DEEPSEEK_API_KEY=COLOQUE_SUA_DEEPSEEK_API_KEY_AQUI
GEMINI_API_KEY=COLOQUE_SUA_GEMINI_API_KEY_AQUI

# E-mail / pagamentos / integrações
RESEND_API_KEY=COLOQUE_SUA_RESEND_API_KEY_AQUI
STRIPE_SECRET_KEY=COLOQUE_SUA_STRIPE_SECRET_KEY_AQUI
STRIPE_WEBHOOK_SECRET=COLOQUE_SEU_STRIPE_WEBHOOK_SECRET_AQUI
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=COLOQUE_SUA_STRIPE_PUBLISHABLE_KEY_AQUI
STRIPE_PRICE_ID_MONTHLY=price_replace-with-monthly-price-id
STRIPE_PRICE_ID_ANNUAL=price_replace-with-annual-price-id

# Feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_REALTIME=true
